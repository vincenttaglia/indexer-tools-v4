# ── Build-Time Variables ────────────────────────────────────────────
# These are embedded into the app during `npm run build` via Vite.
# Not used in Docker deployments (use runtime env vars instead).

# The Graph Protocol API Key (for gateway subgraph queries)
VITE_THEGRAPH_API_KEY=

# dRPC API Key (for RPC calls)
VITE_DRPC_API_KEY=

# ── Docker Runtime Variables ───────────────────────────────────────
# These are read by docker-entrypoint.sh at container start.
# They generate /config.json which the app loads as defaults.
# See docker-compose.yml for full documentation.

# GRAPH_API_KEY=
# DRPC_API_KEY=
# DEFAULT_ACCOUNTS='[{"address":"0x...","chain":"arbitrum-one","label":"My Indexer","agentEndpoint":"","graphmanEndpoint":"","graphmanToken":""}]'
# AGENT_PROXY_URL=http://indexer-agent:8000/
# GRAPHMAN_PROXY_URL=http://graph-node:8050/
